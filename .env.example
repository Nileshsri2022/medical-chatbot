# ============================================================
#  Medical RAG Chatbot - LLM Configuration
#  Copy this file to .env and fill in your values
#  Usage: cp .env.example .env
# ============================================================

# ─── PROVIDER SELECTION ──────────────────────────────────────
# Uncomment ONE provider block below and set your API key.
# All use the OpenAI-compatible chat completions format.

# ─── Option 1: GROQ (Free, fast) ────────────────────────────
# Sign up: https://console.groq.com  →  API Keys
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=gsk_your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile

# ─── Option 2: GOOGLE GEMINI (Free tier) ────────────────────
# Sign up: https://aistudio.google.com/apikey
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_API_KEY=your_gemini_api_key_here
# LLM_MODEL=gemini-2.0-flash

# ─── Option 3: OPENAI (Paid) ────────────────────────────────
# Sign up: https://platform.openai.com/api-keys
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-your_openai_api_key_here
# LLM_MODEL=gpt-4o-mini

# ─── Option 4: NVIDIA NIM (Free tier available) ─────────────
# Sign up: https://build.nvidia.com  →  Get API Key
# LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# LLM_API_KEY=nvapi-your_nvidia_api_key_here
# LLM_MODEL=meta/llama-3.3-70b-instruct

# ─── Option 5: ANY OPENAI-COMPATIBLE SERVER ─────────────────
# Works with: LM Studio, Ollama, vLLM, LocalAI, etc.
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=not-needed
# LLM_MODEL=your-model-name

# ─── SERVER PORTS ────────────────────────────────────────────
LLM_SERVER_PORT=8001
RAG_SERVER_PORT=8002
FRONTEND_PORT=3000
